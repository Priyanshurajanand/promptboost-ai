# Database connection URL (e.g. postgresql://user:password@localhost:5432/dbname)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/promptBoost

# Secure random secret key for JWT token signatures
SECRET_KEY=generate_some_secure_secret_key_string

# Groq API Key (Get yours at https://console.groq.com/keys)
GROQ_API_KEY=your_actual_groq_api_key
